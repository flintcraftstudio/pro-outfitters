PORT=8080

# App identity
APP_NAME=Pro Outfitters
APP_BASE_URL=http://localhost:8080

# SQLite database path. Created if it doesn't exist.
DB_PATH=./data/app.db

# Postmark (transactional email — magic-link auth + inquiry notifications).
# Empty token → dev log sender writes outgoing mail to slog instead.
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM=admin@localhost

# Cleanup worker interval. Sweeps expired sessions + login tokens.
# Default 1h; tune lower for testing.
# CLEANUP_INTERVAL=1h

# Tracking (omit to disable)
GTAG_ID=
PIXEL_ID=

# Cloudflare Turnstile (omit to disable bot protection on the contact form)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
